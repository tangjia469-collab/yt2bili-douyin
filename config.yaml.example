# yt2bili 配置示例
# 复制本文件为 config.yaml 后填写真实值：
#   cp config.yaml.example config.yaml
# 注意：config.yaml 含 API key，已在 .gitignore 中，切勿提交。

# ---------------------------------------------------------------------------
# 授权频道清单：只搬运你有授权的频道
# ---------------------------------------------------------------------------
channels:
  - id: "@example_handle"          # YouTube @handle；也支持 UCxxxx 频道 ID 或频道 URL
    name: 示例频道A                 # 备注名，方便你自己认
    priority: false                # false=自动直发；true=发布前停下等你审核
    # prefer_asr: false            # 可选：覆盖全局字幕源偏好（不写则跟随 defaults）

  - id: UCyyyyyyyyyyyyyyyyyyyyyy   # 也可以继续填传统频道 ID
    name: 示例频道B（重点）
    priority: true                 # 这个频道的视频都要人工审核才发

# ---------------------------------------------------------------------------
# 全局默认值
# ---------------------------------------------------------------------------
defaults:
  prefer_asr: false                # false=优先用 YouTube 自带字幕，没有才本地 ASR
  publish_time: "19:00"            # 发布器每天的发布时刻（仅说明用，实际由 launchd 控制）
  max_duration_min: 60             # 超过这个时长(分钟)的视频自动跳过，不处理
  publish_fail_threshold: 3        # 连续发布失败几次后自动暂停发布器（保账号安全）
  daily_publish_limit: 2           # 每天最多发几条
  min_publish_gap_min: 30          # 两条发布之间至少间隔几分钟
  quality_gate_enabled: true       # true=开启质量门槛；false=发现新视频就处理
  quality_gate_ratio: 0.8          # 点赞数或评论数达到该频道近期平均值的 80% 即通过
  quality_gate_recent_count: 20    # 用每个频道最近多少条视频计算平均值
  quality_gate_min_samples: 3      # 至少拿到多少条有效数据才启用门槛；不足则不跳过
  max_cached_videos: 3             # warehouse 最多保留几个视频目录（active 状态永不自动删）
  max_warehouse_gb: 8.0            # warehouse 总大小上限；超限时删除最旧 inactive 缓存
  min_free_disk_gb: 20.0           # 磁盘剩余空间低于该值时，worker 停止重任务避免拖慢整机
  subtitle_style:                  # 硬烧中文字幕的样式
    font: "PingFang SC"        # 中文字体，macOS 自带（思源黑体需另装）
    font_size: 22
    outline: 1
    margin_v: 30

# ---------------------------------------------------------------------------
# 翻译 API（MiniMax）
# ---------------------------------------------------------------------------
api:
  minimax_key: "在这里填你的MiniMax API Key明文"   # 注意：当前版本不支持 ${ENV} 写法

# ---------------------------------------------------------------------------
# B 站上传（biliup）
# ---------------------------------------------------------------------------
biliup:
  binary: "/Users/itstonga/.local/bin/biliup"   # biliup 可执行文件的绝对路径
  tid: 122                                       # B站分区 ID（122=趣味科普，按需改）
  tags: ["搬运", "中文字幕"]                       # 视频标签
